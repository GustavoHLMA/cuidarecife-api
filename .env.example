NODE_ENV=development
PORT=3001
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL="postgresql://user:password@host:5432/database?connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://user:password@host:5432/database"
GOOGLE_VISION_API_KEY="your_google_vision_api_key"
GEMINI_API_KEY="your_gemini_api_key"
SENTRY_DSN="your_sentry_dsn"

# e-SUS PEC Database (requer VPN)
HOST_PEC="esush.recife"
BANCO_PEC="dbrecsaude_bi"
PORTA_PEC="5432"
SCHEMA_PEC="PUBLIC"
USUARIO_PEC="your_pec_user"
SENHA_PEC="your_pec_password"
